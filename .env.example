# Copy this file to .env and fill in your values.
# For Railway: set these variables in the Railway project dashboard instead.
APP_ENV=development

# Redis connection (self-hosted or external Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Telegram Bot token (from @BotFather)
TELEGRAM_TOKEN=

# Telegram user/chat ID to receive scheduled push notifications
# Get it via @userinfobot or from the Telegram API update payload
TELEGRAM_USER_ID=

# ---------------------------------------------------------------------------
# Scheduled push stock lists (comma-separated, no spaces required)
# ---------------------------------------------------------------------------
# Taiwan stock codes for the TW scheduled push (Mon–Fri 08:30–14:00 Taipei)
TW_STOCKS=0050,2330,2317

# US stock tickers for the US scheduled push (Mon–Fri 17:00–04:00 next day Taipei)
US_STOCKS=AAPL,NVDA,TSLA

# ---------------------------------------------------------------------------
# Rate limiting (sliding window per IP)
# Default values apply to any route not covered by a specific prefix below.
# ---------------------------------------------------------------------------
# Default (all unmatched routes)
RATE_LIMIT_WINDOW=60
RATE_LIMIT_COUNT=10
RATE_LIMIT_BLOCK=600

# /api/v1/stock/* overrides
RATE_LIMIT_STOCK_WINDOW=60
RATE_LIMIT_STOCK_COUNT=60
RATE_LIMIT_STOCK_BLOCK=600

# /api/v1/tgMessage/* and /api/v1/usMessage/* overrides
RATE_LIMIT_TG_WINDOW=60
RATE_LIMIT_TG_COUNT=30
RATE_LIMIT_TG_BLOCK=600

# /api/v1/reports/* overrides (weekly/monthly report preview + send)
RATE_LIMIT_REPORT_WINDOW=60
RATE_LIMIT_REPORT_COUNT=10
RATE_LIMIT_REPORT_BLOCK=600

# ---------------------------------------------------------------------------
# Portfolio integration via Google Sheets CSV export (001-portfolio-sheets)
# ---------------------------------------------------------------------------
# Google Sheets spreadsheet ID — from the URL: /spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEETS_ID=

# Portfolio tab GID — from the URL: ?gid={GID}
GOOGLE_SHEETS_PORTFOLIO_GID=

# Optional split GIDs (preferred for new setups):
# TW portfolio summary tab GID (台股總計算) — if empty, falls back to GOOGLE_SHEETS_PORTFOLIO_GID
GOOGLE_SHEETS_PORTFOLIO_GID_TW=
# TW transaction records tab GID (每筆交易紀錄) — not currently read by code, reserved for future use
GOOGLE_SHEETS_TW_TRANSACTIONS_GID=

# US portfolio summary tab GID (計算未實現損益) — independent from TW
GOOGLE_SHEETS_PORTFOLIO_GID_US=
# US transaction records tab GID (每筆交易紀錄) — not currently read by code, reserved for future use
GOOGLE_SHEETS_US_TRANSACTIONS_GID=

# Redis TTL (seconds) for portfolio cache; default 3600 (1 hour)
PORTFOLIO_CACHE_TTL=3600

# Redis TTL (seconds) for US stock rich-data cache; default 60 (1 minute)
# Keep short so pre-market prices stay fresh during 04:00–09:30 ET
US_STOCK_CACHE_TTL=60

# ---------------------------------------------------------------------------
# Periodic reports (005-signal-history-reports)
# ---------------------------------------------------------------------------
# Monthly regular investment target in TWD (default 100000)
REGULAR_INVESTMENT_TARGET_TWD=100000
